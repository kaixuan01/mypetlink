{
  "ConnectionStrings": {
    "MyPetLinkDb": ""
  },
  "Jwt": {
    "Issuer": "MyPetLink.Api",
    "Audience": "MyPetLink.Client",
    "SigningKey": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "GoogleAuth": {
    "ClientId": ""
  },
  "Storage": {
    "Provider": "Local",
    "LocalRoot": "App_Data/uploads",
    "PublicBaseUrl": ""
  },
  "CloudflareR2": {
    "AccountId": "",
    "AccessKeyId": "",
    "SecretAccessKey": "",
    "ServiceUrl": "",
    "PublicBucketName": "mypetlink-public-media",
    "PrivateBucketName": "mypetlink-private-files",
    "PublicBaseUrl": "https://media.mypetlink.com.my",
    "PresignedUploadExpiryMinutes": 5,
    "PresignedDownloadExpiryMinutes": 5
  },
  "Features": {
    "SmartTagOrderingEnabled": false
  },
  "PublicSite": {
    "BaseUrl": ""
  },
  "DatabaseResilience": {
    "MaxRetryCount": 6,
    "MaxRetryDelaySeconds": 10,
    "ApiRetryAfterSeconds": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

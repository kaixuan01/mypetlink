{
  "ConnectionStrings": {
    "MyPetLinkDb": "Server=(localdb)\\MSSQLLocalDB;Database=MyPetLinkDev;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "MyPetLink.Api",
    "Audience": "MyPetLink.Local",
    "SigningKey": "development-only-my-pet-link-signing-key-change-me",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "GoogleAuth": {
    "ClientId": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://127.0.0.1:3000",
      "http://localhost:3001",
      "http://127.0.0.1:3001"
    ]
  },
  "Storage": {
    "Provider": "Local",
    "LocalRoot": "App_Data/uploads",
    "PublicBaseUrl": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}

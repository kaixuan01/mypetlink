{
  "ConnectionStrings": {
    "MyPetLinkDb": "Server=(localdb)\\MSSQLLocalDB;Database=MyPetLinkDev;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "MyPetLink.Api",
    "Audience": "MyPetLink.Local",
    "SigningKey": "development-only-my-pet-link-signing-key-change-me",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "GoogleAuth": {
    "ClientId": ""
  },
  "AdminSeed": {
    "Emails": []
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://127.0.0.1:3000",
      "http://localhost:3001",
      "http://127.0.0.1:3001"
    ]
  },
  "Storage": {
    "Provider": "Local",
    "LocalRoot": "App_Data/uploads",
    "PublicBaseUrl": ""
  },
  "CloudflareR2": {
    "AccountId": "",
    "AccessKeyId": "",
    "SecretAccessKey": "",
    "ServiceUrl": "",
    "PublicBucketName": "mypetlink-public-media",
    "PrivateBucketName": "mypetlink-private-files",
    "PublicBaseUrl": "https://media.mypetlink.com.my",
    "PresignedUploadExpiryMinutes": 5,
    "PresignedDownloadExpiryMinutes": 5
  },
  "Features": {
    "SmartTagOrderingEnabled": true
  },
  "DatabaseResilience": {
    "MaxRetryCount": 6,
    "MaxRetryDelaySeconds": 10,
    "ApiRetryAfterSeconds": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}

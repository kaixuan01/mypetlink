# Canonical public site URL. Used to build absolute share links and to
# generate QR codes (/p, /q, /t) client-side. Production (e.g. Cloudflare
# Pages) MUST set this before building. Locally it falls back to
# NEXT_PUBLIC_APP_URL, then to window.location.origin.
NEXT_PUBLIC_SITE_URL=https://mypetlink.com.my

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5281
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_SMART_TAG_ORDERING_ENABLED=false
NEXT_PUBLIC_DATABASE_WAKE_MAX_ATTEMPTS=6
NEXT_PUBLIC_DATABASE_WAKE_MAXIMUM_WAIT_SECONDS=45

# Media uploads are signed by the .NET API and uploaded directly to Cloudflare R2.
# Do not add R2 access keys here; NEXT_PUBLIC_* values are visible in the browser.

# Future Supabase setup. Not used by the current frontend MVP.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Future payment setup. Checkout is not implemented yet.
PAYMENT_PROVIDER=
PAYMENT_SECRET_KEY=

# Optional support/contact placeholder.
WHATSAPP_SUPPORT_NUMBER=
